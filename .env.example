# Anthropic API key (required for AI rewrite)
ANTHROPIC_API_KEY=sk-ant-...

# URL the browser uses to reach the backend
# On a remote server, set this to your server's public IP/domain
NEXT_PUBLIC_API_URL=http://localhost:8000

# Comma-separated origins the backend allows (must match where frontend is served from)
ALLOWED_ORIGINS=http://localhost:3000
